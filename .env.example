# Server-side only. Never expose this value in Squarespace or browser code.
OPENAI_API_KEY=

# Recommended starting point for QA. Revisit after the first 50-question pass.
OPENAI_MODEL=gpt-5.4-mini

# Created by the Source Pack upload/sync workflow.
OPENAI_VECTOR_STORE_ID=

# Public URL where the backend will be deployed.
# Example: https://sgf-chatbot.vercel.app
CHATBOT_API_BASE_URL=http://localhost:8787

# The raw form URL must not appear in assistant answer text.
# It is used only behind the persistent Ask a Staff Member button.
PATRON_EXPERIENCE_FORM_URL=https://forms.gle/aYFRTZbEzBzu76k19

# Optional direct escalation destinations.
DEVELOPMENT_EMAIL=development@sterngrove.org
HR_EMAIL=hr@sterngrove.org

# Cost-control recommendation for testing.
RECOMMENDED_OPENAI_TEST_BUDGET_USD=25
